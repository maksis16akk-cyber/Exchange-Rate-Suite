// Атрибуция: Данные предоставлены Exchange Rate API

session_start();

$apiUrl = "https://open.er-api.com/v6/latest/";
$cacheFile = "exchange_cache.json";
$cacheTime = 3600; // 1 час

function fetchRates($base) {
    global $apiUrl;
    $url = $apiUrl . $base;
    $ch = curl_init($url);
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_FOLLOWLOCATION, true);
    curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
    $response = curl_exec($ch);
    $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);
    if ($httpCode == 200) {
        $data = json_decode($response, true);
        if ($data['result'] == 'success') {
            return $data;
        }
    }
    return null;
}

function getRates($base) {
    global $cacheFile, $cacheTime;
    if (file_exists($cacheFile) && (time() - filemtime($cacheFile) < $cacheTime)) {
        $cached = json_decode(file_get_contents($cacheFile), true);
        if ($cached['base'] == $base) {
            return $cached['data'];
        }
    }
    $data = fetchRates($base);
    if ($data) {
        file_put_contents($cacheFile, json_encode(['base' => $base, 'data' => $data]));
    }
    return $data;
}

$base = $_GET['base'] ?? $_SESSION['base'] ?? 'USD';
$data = getRates($base);
$rates = $data['rates'] ?? [];
$updateTime = $data['time_last_update_utc'] ?? 'неизвестно';
$currentBase = $data['base_code'] ?? $base;
$_SESSION['base'] = $currentBase;

$result = null;
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['convert'])) {
    $amount = floatval($_POST['amount']);
    $from = strtoupper($_POST['from']);
    $to = strtoupper($_POST['to']);
    if ($rates && isset($rates[$from]) && isset($rates[$to])) {
        $fromRate = $rates[$from];
        $toRate = $rates[$to];
        $converted = $amount * $toRate / $fromRate;
        $result = sprintf("%.2f %s = %.4f %s", $amount, $from, $converted, $to);
    } else {
        $result = "Ошибка конвертации";
    }
}
