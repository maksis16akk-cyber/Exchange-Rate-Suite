def get_top_movers(rates, previous_rates):
    """Рассчитывает изменение за день в процентах"""
    if not previous_rates:
        return []
    changes = []
    for curr, rate in rates.items():
        if curr.startswith('_'):
            continue
        prev_rate = previous_rates.get(curr)
        if prev_rate and rate:
            change = (rate - prev_rate) / prev_rate * 100
            changes.append((curr, change))
    changes.sort(key=lambda x: x[1], reverse=True)
    return changes[:5]

