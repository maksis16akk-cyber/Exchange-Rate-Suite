"""
exchange.py - Курсы валют на Python (CLI + matplotlib графики)
Требуется установка: pip install requests matplotlib pandas
Атрибуция: Данные предоставлены Exchange Rate API
"""

import requests
import json
import os
import sys
from datetime import datetime, timedelta
from collections import defaultdict

API_URL = "https://open.er-api.com/v6/latest/"

CACHE_FILE = "exchange_cache.json"
CACHE_DURATION = 3600  # 1 час

def load_cache():
    if os.path.exists(CACHE_FILE):
        with open(CACHE_FILE, 'r') as f:
            data = json.load(f)
            if datetime.now().timestamp() - data.get('timestamp', 0) < CACHE_DURATION:
                return data.get('rates')
    return None

def save_cache(rates):
    with open(CACHE_FILE, 'w') as f:
        json.dump({'timestamp': datetime.now().timestamp(), 'rates': rates}, f)

def fetch_rates(base='USD'):
    cached = load_cache()
    if cached:
        print("Использую кэшированные данные")
        return cached
    try:
        response = requests.get(f"{API_URL}{base}")
        response.raise_for_status()
        data = response.json()
        if data.get('result') == 'success':
            rates = data['rates']
            # добавим дату обновления
            rates['_time_last_update'] = data.get('time_last_update_utc', '')
            rates['_base'] = base
            save_cache(rates)
            return rates
        else:
            print(f"Ошибка API: {data}")
            return None
    except Exception as e:
        print(f"Ошибка запроса: {e}")
        return None

def display_rates(rates, base, symbols=None):
    if not rates:
        return
    print(f"\n📊 Курсы валют относительно {base}")
    print(f"🕒 Обновлено: {rates.get('_time_last_update', 'неизвестно')}")
    print("-" * 60)
    # список валют для отображения
    currencies = symbols if symbols else ['USD', 'EUR', 'GBP', 'JPY', 'CNY', 'RUB', 'CAD', 'AUD', 'CHF', 'BTC']
    for curr in currencies:
        if curr == base:
            rate = 1.0
        else:
            rate = rates.get(curr, None)
        if rate is not None:
            print(f"{curr}: {rate:.4f}")
        elif curr != base:
            print(f"{curr}: данные недоступны")
    print("-" * 60)

def convert_currency(rates, from_curr, to_curr, amount):
    if from_curr not in rates or to_curr not in rates:
        print("Одна из валют не найдена")
        return None
    if from_curr == to_curr:
        return amount
    # Конвертация через базовую валюту (которая является ключом в rates)
    # rates - это словарь, где ключи - валюты, значения - курс относительно base
    # Проще: если base != from_curr, нужно привести к cross rate
    # В данном API rates даны относительно base = USD по умолчанию
    # Правильная конвертация:
    usd_to_from = 1.0 / rates[from_curr] if from_curr != 'USD' else 1.0
    usd_to_to = 1.0 / rates[to_curr] if to_curr != 'USD' else 1.0
    result = amount * (usd_to_to / usd_to_from)  # wait, need to double-check
    # Проще: amount in from_curr -> usd -> to_curr
    usd_amount = amount / rates[from_curr]
    result = usd_amount * rates[to_curr]
    return result

